{
  "id": "espbot2-ble",
  "name": "EspBot 2 & BLE Board",
  "meta": { "vendor": "Espressif", "mcu": "esp32c3" },
  "icon": { "preset": "espbot", "faIcon": "fa-robot", "imageRef": "espbot2-ble.jpg" },

  "connection": {
    "baud": 115200,
    "replMode": "raw-paste",
    "resetOnConnect": false,
    "eol": "\r\n"
  },

  "runtime": {
    "dialect": "machine",
    "imports": ["from machine import Pin"]
  },

  "pins": {
    "digital": [0, 1, 3, 4, 5, 6, 7, 10, 20, 21],
    "analog": [0, 1, 3, 4, 5],
    "pwm": [0, 1, 3, 4, 5, 6, 7, 10, 20, 21],
    "dac": [],
    "touch": [],
    "aliases": { "LED": 9 }
  },

  "buses": {
    "i2c": [{ "id": 0, "scl": 6, "sda": 5, "freq": 400000 }],
    "spi": [{ "id": 1, "sck": 4, "mosi": 6, "miso": 5 }],
    "uart": [{ "id": 1, "tx": 21, "rx": 20 }]
  },

  "constraints": {
    "adcBits": 12,
    "adcVref": 3.3,
    "pwmFreqHz": [1, 40000000],
    "logicVoltage": 3.3
  },

  "onboard": [{ "type": "led", "pin": 9, "name": "onboard LED (GPIO9)" }],

  "capabilities": ["gpio", "adc", "pwm", "i2c", "spi", "uart", "wifi", "ble", "espnow", "neopixel"],
  "plugins": [
    "core-control",
    "core-gpio",
    "core-logic",
    "core-math",
    "core-text",
    "core-variables",
    "core-functions",
    "core-neopixel",
    "core-sensors",
    "espbot-motors",
    "espbot-ble",
    "core-espnow"
  ],

  "libraries": [],
  "examples": [
    {
      "id": "ble-robot",
      "name": "BLE robot",
      "description": "Drive with a phone gamepad over Bluetooth",
      "file": "ble-robot.bloq"
    }
  ],

  "presets": {
    "Bluetooth": [
      {
        "kind": "block",
        "type": "ble_begin",
        "inputs": { "NAME": { "shadow": { "type": "text_literal", "fields": { "TEXT": "EspBot" } } } },
        "next": {
          "block": {
            "type": "forever",
            "inputs": {
              "DO": {
                "block": {
                  "type": "if_else",
                  "inputs": {
                    "COND": { "block": { "type": "ble_button", "fields": { "BTN": "ButtonUp", "STATE": "True" } } },
                    "DO": {
                      "block": {
                        "type": "motor_spin",
                        "fields": { "MOTOR": "EspBot.MotorLeftAndRight", "DIR": "EspBot.Forward" },
                        "inputs": { "SPEED": { "shadow": { "type": "math_number", "fields": { "NUM": 60 } } } }
                      }
                    },
                    "ELSE": {
                      "block": { "type": "motor_stop", "fields": { "MOTOR": "EspBot.MotorLeftAndRight" } }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ]
  },

  "overrides": {}
}
